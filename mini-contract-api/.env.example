# 数据库
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/mini_contract

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_HOURS=2
REFRESH_TOKEN_EXPIRE_HOURS=720

# 微信小程序
WECHAT_MINI_APP_ID=wx22db0d6ebe81e2ee
WECHAT_MINI_APP_SECRET=your_app_secret

# 文件存储 (S3 兼容)
S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=mini-contract

# 短信服务
SMS_ACCESS_KEY=your_sms_key
SMS_SECRET_KEY=your_sms_secret
