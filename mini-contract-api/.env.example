# 应用配置
APP_NAME=Mini Contract API
DEBUG=false
API_PREFIX=/app-api

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mini_contract

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT（生产环境请更换为随机字符串）
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2
REFRESH_TOKEN_EXPIRE_HOURS=720

# 文件存储 (S3 兼容 / MinIO)
S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=mini-contract

# 短信服务（阿里云）
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
